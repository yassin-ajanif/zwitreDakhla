<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Auth.ViewModels"
             x:Class="GestionCommerciale.Modules.Auth.Views.LoginView"
             x:DataType="vm:LoginViewModel">
  <Border Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center" MinWidth="380"
          Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="16" BorderThickness="1">
    <StackPanel Spacing="12">
      <TextBlock Text="{Binding LAppTitle}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
      <TextBlock Text="{Binding LSubtitle}" FontSize="16" HorizontalAlignment="Center" Classes="subtle"/>
      <TextBox Watermark="{Binding WmEmail}" Text="{Binding Email}" />
      <TextBox Watermark="{Binding WmPassword}" PasswordChar="*" Text="{Binding Password}" />
      <Button Content="{Binding BtnConnect}" Command="{Binding LoginCommand}" HorizontalAlignment="Stretch"
              IsEnabled="{Binding !IsBusy}" Classes="primary"/>
    </StackPanel>
  </Border>
</UserControl>
