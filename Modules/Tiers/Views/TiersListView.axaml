<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Tiers.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Tiers.Models"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             x:Class="GestionCommerciale.Modules.Tiers.Views.TiersListView"
             x:DataType="vm:TiersListViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBox Width="220" Watermark="{Binding WmSearch}"
               Text="{Binding Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
      <Button Content="{Binding BtnNew}" Command="{Binding OpenNewCommand}"/>
      <Button Content="{Binding BtnToggleActif}" Command="{Binding ToggleActifCommand}"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
      <Border Padding="10,6" BorderThickness="1" CornerRadius="8"
              Background="{DynamicResource CourseraSurfaceMutedBrush}" BorderBrush="{DynamicResource CourseraBorderBrush}">
        <Grid ColumnDefinitions="2*,*,*,Auto">
          <TextBlock Grid.Column="0" Text="{Binding ColNom}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="1" Text="{Binding ColIce}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="2" Text="{Binding ColVille}" FontWeight="SemiBold"/>
          <TextBlock Grid.Column="3" Text="{Binding ColActif}" FontWeight="SemiBold"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" Margin="0,8,0,0"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="m:Tiers">
            <Grid ColumnDefinitions="2*,*,*,Auto">
              <TextBlock Grid.Column="0" Text="{Binding Nom}"/>
              <TextBlock Grid.Column="1" Text="{Binding ICE}"/>
              <TextBlock Grid.Column="2" Text="{Binding Ville}"/>
              <TextBlock Grid.Column="3" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}"/>
            </Grid>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
