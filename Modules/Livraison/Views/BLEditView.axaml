<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Livraison.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Tiers.Models"
             xmlns:stock="using:GestionCommerciale.Modules.Stock.Models"
             xmlns:gc="using:GestionCommerciale.Shared.Controls"
             x:Class="GestionCommerciale.Modules.Livraison.Views.BLEditView"
             x:DataType="vm:BLEditViewModel">
  <ScrollViewer>
    <StackPanel Spacing="10">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="{Binding BtnBack}" Command="{Binding BackCommand}"/>
        <Button Content="{Binding BtnSave}" Command="{Binding SaveCommand}" IsEnabled="{Binding CanEdit}"/>
        <Button Content="{Binding BtnPdf}" Command="{Binding ExportPdfCommand}"/>
        <Button Content="{Binding BtnPrint}" Command="{Binding PrintCommand}"/>
        <Button Content="{Binding BtnToInvoice}" Command="{Binding ToFactureCommand}" IsEnabled="{Binding !HasInvoicedLabel}"/>
      </StackPanel>
      <Border Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8">
        <Border.ContextMenu>
          <ContextMenu Opening="OnHeaderContextMenuOpening">
            <MenuItem Header="{Binding MenuDeleteBl}" Command="{Binding RemoveBlCommand}"/>
          </ContextMenu>
        </Border.ContextMenu>
        <StackPanel Orientation="Horizontal" Spacing="12">
          <TextBlock Text="{Binding Numero}" FontWeight="Bold"/>
          <Border Padding="6,2" Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="4"
                  IsVisible="{Binding HasBccLabel}">
            <TextBlock Text="{Binding BccLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#1E40AF"/>
          </Border>
          <Border Padding="6,2" Background="#DCFCE7" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="4"
                  IsVisible="{Binding HasInvoicedLabel}">
            <TextBlock Text="{Binding InvoicedLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#166534"/>
          </Border>
        </StackPanel>
      </Border>
      <Grid ColumnDefinitions="Auto,12,Auto,20,Auto" VerticalAlignment="Center">
        <TextBlock Grid.Column="0" Text="{Binding LblClient}" VerticalAlignment="Center" Opacity="0.7"/>
        <AutoCompleteBox Grid.Column="2" MinWidth="280" MaxWidth="420"
                         MinimumPrefixLength="1" MaxDropDownHeight="320"
                         Watermark="{Binding WmClientSearch}"
                         ItemsSource="{Binding Clients}"
                         ItemFilter="{Binding PartyAutocompleteFilter}"
                         SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                         IsEnabled="{Binding CanEdit}">
          <AutoCompleteBox.ValueMemberBinding>
            <Binding Path="Nom"/>
          </AutoCompleteBox.ValueMemberBinding>
          <AutoCompleteBox.ItemTemplate>
            <DataTemplate DataType="m:Tiers">
              <TextBlock Text="{Binding Nom}"/>
            </DataTemplate>
          </AutoCompleteBox.ItemTemplate>
        </AutoCompleteBox>
        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <TextBlock Text="{Binding LblDateBl}" VerticalAlignment="Center" Opacity="0.7"/>
          <DatePicker SelectedDate="{Binding Date}"/>
        </StackPanel>
      </Grid>
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <TextBlock Text="{Binding LblLinkedBcc}" Opacity="0.7" VerticalAlignment="Center"/>
        <Button Content="{Binding BtnAddBcc}" Command="{Binding ShowBccPickerCommand}" IsEnabled="{Binding CanEdit}"/>
        <TextBox MinWidth="180" MaxWidth="320" VerticalAlignment="Center"
                 Watermark="{Binding WmBonCommandeReference}"
                 Text="{Binding BonCommandeReference, Mode=TwoWay}"
                 IsEnabled="{Binding CanEdit}"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="{Binding LblAddProduct}" VerticalAlignment="Center" Opacity="0.7"/>
        <AutoCompleteBox MinWidth="360" MaxWidth="520" VerticalAlignment="Center"
                         MinimumPrefixLength="1" MaxDropDownHeight="320"
                         Watermark="{Binding WmAddProduct}"
                         ItemsSource="{Binding Produits}"
                         ItemFilter="{Binding ProduitAutocompleteFilter}"
                         Text="{Binding AddLineSearchText, Mode=TwoWay}"
                         SelectedItem="{Binding AddLineCatalogPick, Mode=TwoWay}"
                         IsEnabled="{Binding CanEdit}">
          <AutoCompleteBox.ValueMemberBinding>
            <Binding Path="Reference"/>
          </AutoCompleteBox.ValueMemberBinding>
          <AutoCompleteBox.ItemTemplate>
            <DataTemplate DataType="stock:Produit">
              <TextBlock TextWrapping="Wrap">
                <TextBlock.Text>
                  <MultiBinding StringFormat="{}{0} — {1}">
                    <Binding Path="Reference"/>
                    <Binding Path="Designation"/>
                  </MultiBinding>
                </TextBlock.Text>
              </TextBlock>
            </DataTemplate>
          </AutoCompleteBox.ItemTemplate>
        </AutoCompleteBox>
        <Button Content="{Binding BtnRemoveLine}" Command="{Binding RemoveSelectedLineCommand}" IsEnabled="{Binding CanEdit}"/>
      </StackPanel>
      <TextBlock Text="{Binding LblDocLineColumnsHint}" FontSize="11" Opacity="0.75" FontWeight="SemiBold"/>
      <WrapPanel Orientation="Horizontal">
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowReference}" Content="{Binding LblDocColRef}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowDesignation}" Content="{Binding LblDocColDesignation}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowQuantite}" Content="{Binding LblDocColQte}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowConditionnement}" Content="{Binding LblDocColCond}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowPuHt}" Content="{Binding LblDocColPuHt}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowRemise}" Content="{Binding LblDocColRemise}" IsVisible="{Binding LineGridColumns.SupportsLineRemise}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowTva}" Content="{Binding LblDocColTva}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowMontantHt}" Content="{Binding LblDocColMontantHt}"/>
        <CheckBox Margin="0,0,12,4" IsChecked="{Binding LineGridColumns.ShowMontantTtc}" Content="{Binding LblDocColMontantTtc}"/>
      </WrapPanel>
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <Grid MinWidth="880" RowDefinitions="Auto,*">
          <Border Grid.Row="0" BorderBrush="{DynamicResource CourseraBorderBrush}" BorderThickness="1" CornerRadius="8,8,0,0"
                  Background="{DynamicResource CourseraSurfaceMutedBrush}" Padding="8,8">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColRef}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColDesignation}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColQte}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColCond}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColPuHt}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColRemise}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColTva}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColMontantHt}"/>
                <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColMontantTtc}"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding LblDocColRef}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowReference}"/>
              <TextBlock Grid.Column="1" Text="{Binding LblDocColDesignation}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowDesignation}"/>
              <TextBlock Grid.Column="2" Text="{Binding LblDocColQte}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowQuantite}"/>
              <TextBlock Grid.Column="3" Text="{Binding LblDocColCond}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowConditionnement}"/>
              <TextBlock Grid.Column="4" Text="{Binding LblDocColPuHt}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowPuHt}"/>
              <TextBlock Grid.Column="5" Text="{Binding LblDocColRemise}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowRemise}"/>
              <TextBlock Grid.Column="6" Text="{Binding LblDocColTva}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowTva}"/>
              <TextBlock Grid.Column="7" Text="{Binding LblDocColMontantHt}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"
                         IsVisible="{Binding LineGridColumns.ShowMontantHt}"/>
              <TextBlock Grid.Column="8" Text="{Binding LblDocColMontantTtc}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"
                         IsVisible="{Binding LineGridColumns.ShowMontantTtc}"/>
            </Grid>
          </Border>
          <ListBox Grid.Row="1" ItemsSource="{Binding Lignes}" SelectedItem="{Binding SelectedLine}" MinHeight="200"
                   BorderThickness="1" BorderBrush="{DynamicResource CourseraBorderBrush}" CornerRadius="0,0,8,8"
                   Background="{DynamicResource CourseraSurfaceBrush}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="vm:BLLineRow">
                <Border Padding="6,2" BorderBrush="#18000000" BorderThickness="0,0,0,1">
                  <Grid MinHeight="34">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColRef}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColDesignation}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColQte}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColCond}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColPuHt}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColRemise}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColTva}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColMontantHt}"/>
                      <ColumnDefinition Width="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ColMontantTtc}"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding Reference}"
                             Watermark="Réf."
                             Padding="6,4"
                             Margin="0,0,8,0"
                             IsReadOnly="{Binding !$parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                             IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowReference}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Designation}"
                             Watermark="…"
                             Padding="6,4"
                             Margin="0,0,8,0"
                             IsReadOnly="{Binding !$parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                             IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowDesignation}"/>
                    <NumericUpDown Grid.Column="2" ShowButtonSpinner="False" Value="{Binding QuantiteLivree}" FormatString="0.##" Minimum="0" Increment="1"
                                   HorizontalAlignment="Stretch" Margin="0,0,8,0"
                                   IsEnabled="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                                   IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowQuantite}"/>
                    <TextBox Grid.Column="3" Text="{Binding Conditionnement}" Watermark="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).WmDocLineUnite}" Padding="6,4" Margin="0,0,8,0"
                             IsReadOnly="{Binding !$parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                             IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowConditionnement}"/>
                    <NumericUpDown Grid.Column="4" ShowButtonSpinner="False" Value="{Binding PrixUnitaireHt}" FormatString="0.##" Minimum="0" Increment="0.01"
                                   HorizontalAlignment="Stretch" Margin="0,0,8,0"
                                   IsEnabled="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                                   IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowPuHt}"/>
                    <NumericUpDown Grid.Column="5" ShowButtonSpinner="False" Value="{Binding Remise}" FormatString="N2" Minimum="0" Maximum="100" Increment="1"
                                   HorizontalAlignment="Stretch" Margin="0,0,8,0"
                                   IsEnabled="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                                   IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowRemise}"/>
                    <NumericUpDown Grid.Column="6" ShowButtonSpinner="False" Value="{Binding TauxTva}" FormatString="0.##" Minimum="0" Increment="1"
                                   HorizontalAlignment="Stretch" Margin="0,0,8,0"
                                   IsEnabled="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).CanEdit}"
                                   IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowTva}"/>
                    <TextBlock Grid.Column="7" Text="{Binding MontantHt, StringFormat=\{0:N2\}}" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Margin="0,0,8,0" Opacity="0.9"
                               IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowMontantHt}"/>
                    <TextBlock Grid.Column="8" Text="{Binding MontantTtc, StringFormat=\{0:N2\}}" VerticalAlignment="Center"
                               HorizontalAlignment="Right" Opacity="0.9"
                               IsVisible="{Binding $parent[UserControl].((vm:BLEditViewModel)DataContext).LineGridColumns.ShowMontantTtc}"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </ScrollViewer>
      <Grid Margin="0,8,0,0" ColumnDefinitions="*,16,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding Note}"
                 AcceptsReturn="True"
                 MinHeight="88"
                 VerticalContentAlignment="Top"
                 VerticalAlignment="Stretch"
                 IsReadOnly="{Binding !CanEdit}"/>
        <Border Grid.Column="2"
                Padding="14,10"
                MinWidth="220"
                VerticalAlignment="Top"
                Background="#EEF2FF"
                BorderBrush="#C7D2FE"
                BorderThickness="1"
                CornerRadius="6"
                BoxShadow="0 1 4 0 #18000000">
          <StackPanel Spacing="6" HorizontalAlignment="Right">
            <TextBlock Text="{Binding LblTotals}" FontSize="11" Opacity="0.65" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            <TextBlock Text="{Binding TotalHtLabel}" FontSize="13" HorizontalAlignment="Right" IsVisible="{Binding ShowTotalTtc}"/>
            <TextBlock Text="{Binding TotalHtLabel}"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="#3730A3"
                       HorizontalAlignment="Right"
                       IsVisible="{Binding !ShowTotalTtc}"/>
            <TextBlock Text="{Binding TotalTvaLabel}" FontSize="13" HorizontalAlignment="Right" IsVisible="{Binding ShowTotalTva}"/>
            <TextBlock Text="{Binding TotalTtcLabel}"
                       FontSize="17"
                       FontWeight="Bold"
                       Foreground="#3730A3"
                       HorizontalAlignment="Right"
                       IsVisible="{Binding ShowTotalTtc}"/>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
