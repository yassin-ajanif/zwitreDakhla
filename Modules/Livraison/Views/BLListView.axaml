<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Livraison.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Livraison.Views.BLListView"
             x:Name="BLListRoot"
             x:DataType="vm:BLListViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewBlCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <Button Content="{Binding BtnFacturerSelection}" Command="{Binding FacturerSelectionCommand}"/>
      <TextBox MinWidth="260" MaxWidth="420" VerticalAlignment="Center"
               Watermark="{Binding SearchWatermark}" Text="{Binding SearchText}"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
      <Border Grid.Row="0" Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8" Margin="0,0,0,1">
        <Grid ColumnDefinitions="32,120,*,110,100,*,150">
          <TextBlock Grid.Column="1" Text="{Binding ColHeaderRef}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="{Binding ColHeaderParty}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHeaderDate}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="{Binding ColHeaderTtc}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="5" Text="{Binding ColHeaderNote}" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="6" Text="{Binding ColHeaderInvoiced}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:BLListRow">
            <Border Padding="10,8" Background="Transparent">
              <Border.ContextMenu>
                <ContextMenu Opening="OnRowContextMenuOpening">
                  <MenuItem Header="{Binding #BLListRoot.((vm:BLListViewModel)DataContext).MenuDeleteBl}"
                            Command="{Binding #BLListRoot.((vm:BLListViewModel)DataContext).DeleteBlCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="32,120,*,110,100,*,150">
                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" IsVisible="{Binding CanInvoice}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding Bl.Numero}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding ClientNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding DateShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" Text="{Binding TtcLabel}" VerticalAlignment="Center" FontWeight="SemiBold" TextAlignment="End" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="5" Text="{Binding NotePreview}" VerticalAlignment="Center" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                <Border Grid.Column="6"
                        Padding="6,2"
                        Background="#DCFCE7"
                        BorderBrush="#86EFAC"
                        BorderThickness="1"
                        CornerRadius="4"
                        HorizontalAlignment="Right"
                        IsVisible="{Binding HasInvoicedLabel}">
                  <TextBlock Text="{Binding InvoicedLabel}"
                             FontSize="11"
                             FontWeight="SemiBold"
                             Foreground="#166534"/>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
