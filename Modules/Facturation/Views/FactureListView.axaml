<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Facturation.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Facturation.Views.FactureListView"
             x:Name="FactureListRoot"
             x:DataType="vm:FactureListViewModel">
  <UserControl.Styles>
    <Style Selector="Border.facture-overdue">
      <Setter Property="Background" Value="#FEE2E2"/>
    </Style>
    <Style Selector="Border.facture-overdue TextBlock.overdue-highlight">
      <Setter Property="Foreground" Value="#DC2626"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </UserControl.Styles>
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewFactureCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <ComboBox Width="220" PlaceholderText="{Binding WmFilterPayee}" SelectedIndex="{Binding PayeeFilterIndex}">
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureListRoot.((vm:FactureListViewModel)DataContext).LblPayeeFilterAll}"/>
        </ComboBoxItem>
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureListRoot.((vm:FactureListViewModel)DataContext).LblPayeeFilterUnpaid}"/>
        </ComboBoxItem>
        <ComboBoxItem>
          <TextBlock Text="{Binding #FactureListRoot.((vm:FactureListViewModel)DataContext).LblPayeeFilterPaid}"/>
        </ComboBoxItem>
      </ComboBox>
      <TextBox MinWidth="260" MaxWidth="420" VerticalAlignment="Center"
               Watermark="{Binding SearchWatermark}" Text="{Binding SearchText}"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
      <Border Grid.Row="0" Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8" Margin="0,0,0,1">
        <Grid ColumnDefinitions="*,*,100,100,118,100,*">
          <TextBlock Grid.Column="0" Text="{Binding ColHeaderRef}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" Text="{Binding ColHeaderParty}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="{Binding ColHeaderDate}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHeaderEcheance}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="{Binding ColHeaderPayee}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="5" Text="{Binding ColHeaderTtc}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="6" Text="{Binding ColHeaderNote}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:FactureListRow">
            <Border Padding="10,8" Background="Transparent" Classes.facture-overdue="{Binding IsOverdue}">
              <Border.ContextMenu>
                <ContextMenu Opening="OnRowContextMenuOpening">
                  <MenuItem Header="{Binding #FactureListRoot.((vm:FactureListViewModel)DataContext).MenuDeleteFacture}"
                            Command="{Binding #FactureListRoot.((vm:FactureListViewModel)DataContext).DeleteFactureCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="*,*,100,100,118,100,*">
                <TextBlock Grid.Column="0" Text="{Binding Facture.Numero}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding ClientNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding DateShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Classes="overdue-highlight" Text="{Binding EcheanceShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" Classes="overdue-highlight" Text="{Binding StatutLabel}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="5" Text="{Binding TtcLabel}" VerticalAlignment="Center" FontWeight="SemiBold" TextAlignment="End" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="6" Text="{Binding NotePreview}" VerticalAlignment="Center" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
