<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Stock.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Stock.Models"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Stock.Views.StockMainView"
             x:DataType="vm:StockMainViewModel">
  <Grid ColumnDefinitions="*,*">
      <Border Padding="12" CornerRadius="8" BorderBrush="#28000000" BorderThickness="1"
              Background="#06000000">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <TextBlock Text="{Binding LblCatalog}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <TextBlock Grid.Row="1" Text="{Binding HelpStock}"
                     TextWrapping="Wrap" Opacity="0.75" FontSize="12" Margin="0,0,0,8"/>
          <TextBox Grid.Row="2" Text="{Binding ProductSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Watermark="{Binding WmSearch}" Margin="0,0,0,8"/>
          <Grid Grid.Row="3" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0" Background="#12000000" CornerRadius="4,4,0,0" Padding="10,8" BorderBrush="#20000000" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="100,*,88,88">
                <TextBlock Text="{Binding ColRef}" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="{Binding ColDesignation}" FontWeight="SemiBold" FontSize="12"/>
                <TextBlock Grid.Column="2" Text="{Binding ColStock}" FontWeight="SemiBold" FontSize="12" TextAlignment="Right"/>
                <TextBlock Grid.Column="3" Text="{Binding ColMinDot}" FontWeight="SemiBold" FontSize="12" TextAlignment="Right"/>
              </Grid>
            </Border>
            <ListBox Grid.Row="1" ItemsSource="{Binding Produits}" SelectedItem="{Binding SelectedProduit}"
                     BorderThickness="0" Background="Transparent">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="10,8"/>
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="m:Produit">
                  <Grid ColumnDefinitions="100,*,88,88">
                    <TextBlock Text="{Binding Reference}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Designation}" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="{Binding StockActuel, StringFormat={}{0:N0}}"
                               TextAlignment="Right" VerticalAlignment="Center"
                               Foreground="{Binding ., Converter={x:Static conv:StockMinForegroundConverter.Instance}}"/>
                    <TextBlock Grid.Column="3" Text="{Binding StockMinimum, StringFormat={}{0:N0}}"
                               TextAlignment="Right" VerticalAlignment="Center" Opacity="0.85"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1" Margin="16,0,0,0" Padding="12" CornerRadius="8" BorderBrush="#28000000" BorderThickness="1"
              Background="#06000000">
        <Grid RowDefinitions="Auto,Auto,*">
          <TextBlock Text="{Binding LblAdjustHistory}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
          <Border Grid.Row="1" Padding="12" Margin="0,0,0,12" CornerRadius="6"
                  Background="#0A000000" BorderBrush="#20000000" BorderThickness="1">
            <StackPanel Spacing="10">
              <TextBlock Text="{Binding LblAdjustManual}" FontSize="12" Opacity="0.85"/>
              <Grid ColumnDefinitions="120,*,Auto">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding LblVariation}" FontSize="11" Opacity="0.65"/>
                  <NumericUpDown Value="{Binding AjustementDelta}" FormatString="N2" Minimum="-999999" Maximum="999999"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0,12,0" Spacing="4">
                  <TextBlock Text="{Binding LblMotifTrace}" FontSize="11" Opacity="0.65"/>
                  <TextBox Text="{Binding AjustementNote}" Watermark="{Binding WmAdjustNote}"/>
                </StackPanel>
                <Button Grid.Column="2" Content="{Binding BtnApply}" VerticalAlignment="Bottom" MinWidth="100" Padding="14,8"
                        Command="{Binding AjustementCommand}"/>
              </Grid>
            </StackPanel>
          </Border>
          <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto,*,Auto">
            <TextBlock Text="{Binding LblMovements}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
            <TextBox Grid.Row="1" Text="{Binding MovementPartySearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="{Binding WmMovementPartySearch}" Margin="0,0,0,8"/>
            <Border Grid.Row="2" Background="#12000000" CornerRadius="4,4,0,0" Padding="10,8" BorderBrush="#20000000" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="108,*,96,72,80">
                <TextBlock Text="{Binding ColDate}" FontWeight="SemiBold" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ColDetail}" FontWeight="SemiBold" FontSize="11" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="2" Text="{Binding ColBeforeQty}" FontWeight="SemiBold" FontSize="11" TextAlignment="Right" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding ColQty}" FontWeight="SemiBold" FontSize="11" TextAlignment="Right" Margin="0,0,6,0"/>
                <TextBlock Grid.Column="4" Text="{Binding ColStockCurrent}" FontWeight="SemiBold" FontSize="11" TextAlignment="Right"/>
              </Grid>
            </Border>
            <ListBox Grid.Row="3" ItemsSource="{Binding Mouvements}" BorderThickness="0" Background="Transparent">
              <ListBox.Styles>
                <Style Selector="ListBoxItem">
                  <Setter Property="Padding" Value="10,8"/>
                  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
                <Style Selector="ListBoxItem /template/ ContentPresenter">
                  <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
              </ListBox.Styles>
              <ListBox.ItemTemplate>
                <DataTemplate DataType="m:MouvementStock">
                  <Grid ColumnDefinitions="108,*,96,72,80" HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}" FontSize="11" VerticalAlignment="Top"/>
                    <Border Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                      <StackPanel Spacing="2">
                      <Border Padding="6,2" CornerRadius="4" HorizontalAlignment="Left"
                              Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1"
                              IsVisible="{Binding IsModification}">
                        <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#C2410C"/>
                      </Border>
                      <Border Padding="6,2" CornerRadius="4" HorizontalAlignment="Left"
                              Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1"
                              IsVisible="{Binding IsAnnulation}">
                        <TextBlock Text="{Binding StatusLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#DC2626"/>
                      </Border>
                      <Button Command="{Binding $parent[UserControl].((vm:StockMainViewModel)DataContext).OpenCommandeProductionCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding HasCommandeChip}"
                              Padding="0"
                              MinHeight="0"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Left"
                              Cursor="Hand">
                        <Border Padding="6,2" Background="#DBEAFE" BorderBrush="#93C5FD" BorderThickness="1" CornerRadius="4">
                          <TextBlock Text="{Binding CommandeChipLabel}" FontSize="10" FontWeight="SemiBold" Foreground="#1E40AF"/>
                        </Border>
                      </Button>
                      <Button Command="{Binding $parent[UserControl].((vm:StockMainViewModel)DataContext).OpenPrimaryDocumentCommand}"
                              CommandParameter="{Binding}"
                              IsVisible="{Binding HasPrimaryChip}"
                              Padding="0"
                              MinHeight="0"
                              Background="Transparent"
                              BorderThickness="0"
                              HorizontalAlignment="Left"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Left"
                              Cursor="Hand">
                        <Panel>
                          <Border Padding="6,2" Background="#D1FAE5" BorderBrush="#6EE7B7" BorderThickness="1" CornerRadius="4"
                                  IsVisible="{Binding PrimaryChipIsBonReception}">
                            <TextBlock Text="{Binding PrimaryChipLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#047857"/>
                          </Border>
                          <Border Padding="6,2" Background="#F3F4F6" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="4"
                                  IsVisible="{Binding !PrimaryChipIsBonReception}">
                            <TextBlock Text="{Binding PrimaryChipLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#374151"/>
                          </Border>
                        </Panel>
                      </Button>
                      <TextBlock Text="{Binding DocumentDateTime}" FontSize="10" Opacity="0.65"
                                 IsVisible="{Binding ShowDocumentDateTime}"/>
                      <TextBlock Text="{Binding PartyName}" FontSize="10" FontWeight="SemiBold"
                                 Foreground="{Binding PartyColorSignal, Converter={x:Static conv:PositiveNegativeForegroundConverter.Instance}}"
                                 IsVisible="{Binding HasPartyName}"/>
                      <TextBlock Text="{Binding NoteBody}" FontSize="11" Opacity="0.85"
                                 TextWrapping="Wrap"
                                 HorizontalAlignment="Stretch"
                                 IsVisible="{Binding ShowAdjustmentDetail}"/>
                      <TextBlock Text="{Binding UnitPriceDetail}" FontSize="10" Opacity="0.75"
                                 IsVisible="{Binding HasUnitPriceDetail}"/>
                      </StackPanel>
                    </Border>
                    <TextBlock Grid.Column="2" Text="{Binding StockAvant, StringFormat={}{0:N0}}" TextAlignment="Right" VerticalAlignment="Top" Margin="0,0,12,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding QuantiteSignedLabel}" TextAlignment="Right" VerticalAlignment="Top"
                               TextWrapping="NoWrap" Margin="0,0,6,0" FontWeight="SemiBold"
                               Foreground="{Binding SignedQuantite, Converter={x:Static conv:PositiveNegativeForegroundConverter.Instance}}"/>
                    <TextBlock Grid.Column="4" Text="{Binding StockApres, StringFormat={}{0:N0}}"
                               TextAlignment="Right" FontSize="11" VerticalAlignment="Top"/>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
            <shared:ListPaginationBar Grid.Row="4" DataContext="{Binding MouvementPagination}"/>
          </Grid>
        </Grid>
      </Border>
  </Grid>
</UserControl>
