<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.AvoirFournisseur.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.AvoirFournisseur.Views.AvoirFournisseurListView"
              x:Name="AvoirFournisseurListRoot"
             x:DataType="vm:AvoirFournisseurListViewModel">
  <Grid RowDefinitions="Auto,*,Auto" Margin="0,0,0,8">
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
      <Button Content="{Binding BtnNew}" Command="{Binding NewCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <TextBox MinWidth="180" Watermark="{Binding SearchText, TargetNullValue='Rechercher…'}"
               Text="{Binding SearchText}" Margin="12,0,0,0"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*">
      <Border Grid.Row="0" Padding="8,6" Background="{DynamicResource CourseraSurfaceMutedBrush}"
              CornerRadius="8,8,0,0" BorderThickness="1,1,1,0"
              BorderBrush="{DynamicResource CourseraBorderBrush}">
        <Grid ColumnDefinitions="200,*,100,100,100,*">
          <TextBlock Grid.Column="0" Text="{Binding ColNumero}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" Text="{Binding ColFournisseur}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="{Binding ColDate}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHt}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="{Binding ColTtc}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="5" Text="{Binding ColMotif}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Rows}" SelectedItem="{Binding Selected}"
               BorderThickness="1,0,1,1" BorderBrush="{DynamicResource CourseraBorderBrush}"
               CornerRadius="0,0,0,0" Background="{DynamicResource CourseraSurfaceBrush}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:AvoirFournisseurListRow">
            <Border Padding="8,6" Background="Transparent">
              <Border.ContextMenu>
                <ContextMenu Opening="OnRowContextMenuOpening">
                  <MenuItem Header="Supprimer" Command="{Binding $parent[UserControl].((vm:AvoirFournisseurListViewModel)DataContext).DeleteCommand}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="200,*,100,100,100,*">
                <TextBlock Grid.Column="0" Text="{Binding Doc.Numero}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding FournisseurNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding DateShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding HtLabel}" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" Text="{Binding TtcLabel}" VerticalAlignment="Center" TextAlignment="End" FontWeight="SemiBold" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="5" Text="{Binding NotePreview}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Opacity="0.85"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
