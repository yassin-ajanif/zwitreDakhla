<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Charges.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Charges.Models"
             xmlns:t="using:GestionCommerciale.Modules.Tiers.Models"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Charges.Views.ChargeEditView"
             x:DataType="vm:ChargeEditViewModel">
  <Grid ColumnDefinitions="*,280" Margin="0,0,0,8">
    <ScrollViewer Grid.Column="0">
      <StackPanel Spacing="10" Margin="0,0,12,0">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="{Binding BtnBack}" Command="{Binding BackCommand}"/>
          <Button Content="{Binding BtnSave}" Command="{Binding SaveCommand}"/>
        </StackPanel>

        <Border Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8">
          <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
            <TextBlock Grid.Column="0"
                       Text="{Binding Numero}"
                       FontWeight="Bold"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"
                       TextTrimming="CharacterEllipsis"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="{Binding LblCategorie}" VerticalAlignment="Center" Opacity="0.7"/>
              <ComboBox MinWidth="200" MaxWidth="320"
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategorie, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="m:CategorieCharge">
                    <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="16,0,0,0">
              <TextBlock Text="{Binding LblFactPayee}" VerticalAlignment="Center" Opacity="0.7"/>
              <ToggleSwitch IsChecked="{Binding EstPayee, Mode=TwoWay}"
                            OnContent="{Binding LblPaid}"
                            OffContent="{Binding LblUnpaid}"/>
            </StackPanel>
          </Grid>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="16">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding LblDate}" VerticalAlignment="Center" Opacity="0.7"/>
            <DatePicker SelectedDate="{Binding Date}"/>
          </StackPanel>
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Text="{Binding LblLibelle}"/>
          <TextBox Watermark="{Binding LblLibelle}" Text="{Binding Libelle}"/>
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Text="{Binding LblFournisseur}"/>
          <AutoCompleteBox MinWidth="280" MaxWidth="420"
                           MinimumPrefixLength="1" MaxDropDownHeight="320"
                           Watermark="{Binding WmFournisseurSearch}"
                           ItemsSource="{Binding Fournisseurs}"
                           ItemFilter="{Binding PartyAutocompleteFilter}"
                           SelectedItem="{Binding SelectedFournisseur, Mode=TwoWay}">
            <AutoCompleteBox.ValueMemberBinding>
              <Binding Path="Nom"/>
            </AutoCompleteBox.ValueMemberBinding>
            <AutoCompleteBox.ItemTemplate>
              <DataTemplate DataType="t:Tiers">
                <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
              </DataTemplate>
            </AutoCompleteBox.ItemTemplate>
          </AutoCompleteBox>
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Text="{Binding LblFournisseurLibre}"/>
          <TextBox Watermark="{Binding WmFournisseurLibre}" Text="{Binding Fournisseur}"/>
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Text="{Binding LblMontant}"/>
          <NumericUpDown Minimum="0" Maximum="999999999" FormatString="N2" Value="{Binding MontantTtc}"/>
        </StackPanel>

        <StackPanel Spacing="3">
          <TextBlock Text="{Binding LblNote}"/>
          <TextBox Watermark="{Binding LblNote}" Text="{Binding Note}" AcceptsReturn="True" MinHeight="72"/>
        </StackPanel>

        <Button Content="{Binding MenuDeleteCharge}" Command="{Binding RemoveChargeCommand}"
                HorizontalAlignment="Left" IsVisible="{Binding ShowDelete}"/>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Column="1"
            Padding="12"
            Background="{DynamicResource CourseraSurfaceBrush}"
            BorderBrush="{DynamicResource CourseraBorderBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Top" Text="{Binding LblTypesPanel}" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10"/>

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
          <TextBox Watermark="{Binding WmNewCategory}" Text="{Binding NewCategoryNom, Mode=TwoWay}"/>
          <Button Content="{Binding BtnAddCategory}" Command="{Binding AddCategoryCommand}" HorizontalAlignment="Stretch"/>
        </StackPanel>

        <Grid DockPanel.Dock="Top" RowDefinitions="Auto,*" Margin="0,0,0,8">
          <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
            <TextBlock Grid.Column="0" Text="{Binding ColCategoryNom}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="{Binding ColCategoryActif}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
          </Grid>
          <ListBox Grid.Row="1"
                   ItemsSource="{Binding AllCategories}"
                   SelectedItem="{Binding SelectedPanelCategory}"
                   MaxHeight="420"
                   beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditPanelCategoryCommand}">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="m:CategorieCharge">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0" Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Grid.Column="1" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}" Opacity="0.85"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

        <StackPanel DockPanel.Dock="Bottom" Spacing="8">
          <Button Content="{Binding BtnUseCategory}" Command="{Binding UsePanelCategoryCommand}" HorizontalAlignment="Stretch"/>
          <Button Content="{Binding BtnEditCategory}" Command="{Binding EditPanelCategoryCommand}" HorizontalAlignment="Stretch"/>
        </StackPanel>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
