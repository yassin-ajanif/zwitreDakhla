<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Charges.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Charges.Views.ChargeListView"
             x:Name="ChargeListRoot"
             x:DataType="vm:ChargeListViewModel">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewChargeCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
      <TextBox MinWidth="260" MaxWidth="420" VerticalAlignment="Center"
               Watermark="{Binding SearchWatermark}" Text="{Binding SearchText}"/>
    </StackPanel>
    <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,8,0,0">
      <Border Grid.Row="0" Background="{DynamicResource CourseraSurfaceBrush}" CornerRadius="8,8,0,0" Padding="10,8" Margin="0,0,0,1">
        <Grid ColumnDefinitions="*,*,*,100,100,*">
          <TextBlock Grid.Column="0" Text="{Binding ColHeaderRef}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="1" Text="{Binding ColHeaderCategorie}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="2" Text="{Binding ColHeaderBeneficiaire}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="3" Text="{Binding ColHeaderDate}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="4" Text="{Binding ColHeaderMontant}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="End" Margin="0,0,12,0"/>
          <TextBlock Grid.Column="5" Text="{Binding ColHeaderLibelle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </Grid>
      </Border>
      <ListBox Grid.Row="1" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding OpenSelectedCommand}">
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ChargeListRow">
            <Border Padding="10,8" Background="Transparent">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="{Binding #ChargeListRoot.((vm:ChargeListViewModel)DataContext).MenuDeleteCharge}"
                            Command="{Binding #ChargeListRoot.((vm:ChargeListViewModel)DataContext).DeleteChargeCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>
              <Grid ColumnDefinitions="*,*,*,100,100,*">
                <TextBlock Grid.Column="0" Text="{Binding Charge.Numero}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding CategorieNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="2" Text="{Binding BeneficiaireNom}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="3" Text="{Binding DateShort}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="4" Text="{Binding MontantLabel}" VerticalAlignment="Center" FontWeight="SemiBold" TextAlignment="End" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="5" Text="{Binding LibellePreview}" VerticalAlignment="Center" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Grid>
    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
