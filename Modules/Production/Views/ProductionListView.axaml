<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Production.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Production.Views.ProductionListView"
             x:Name="ProductionListRoot"
             x:DataType="vm:ProductionListViewModel">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewOperationCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
      <ListBox ItemsSource="{Binding Operations}"
               SelectedItem="{Binding Selected}"
               Background="Transparent"
               BorderThickness="0"
               Padding="0"
               beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditSelectedCommand}">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:ProductionOperation">
            <Border Background="{DynamicResource CourseraSurfaceBrush}"
                    BorderBrush="{DynamicResource CourseraBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    ClipToBounds="True">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).MenuDelete}"
                            Command="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).DeleteOperationCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>

              <Grid RowDefinitions="Auto,Auto">
                <Border Grid.Row="0"
                        Padding="14,10"
                        Background="{DynamicResource CourseraSurfaceMutedBrush}"
                        BorderBrush="{DynamicResource CourseraBorderBrush}"
                        BorderThickness="0,0,0,1">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                      <Border Width="3" Height="22" CornerRadius="2"
                              Background="{DynamicResource CourseraPrimaryBrush}"/>
                      <TextBlock Text="{Binding DateShort}" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding ModifiedAtLabel}"
                                 FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource CourseraDangerBrush}"
                                 IsVisible="{Binding WasModified}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblTotalOperation}"
                                 Opacity="0.7" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding TotalOperationLabel}"
                                 FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>

                <Grid Grid.Row="1"
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="120,1,*,1,*,1,*">
                  <!-- Section backgrounds -->
                  <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                          Background="{DynamicResource ProdVendreBgBrush}"
                          CornerRadius="8" Margin="0,8,4,8"/>
                  <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="3"
                          Background="{DynamicResource ProdRetournerBgBrush}"
                          CornerRadius="8" Margin="4,8,4,8"/>
                  <Border Grid.Row="0" Grid.Column="6" Grid.RowSpan="3"
                          Background="{DynamicResource CourseraStockAlertBgBrush}"
                          CornerRadius="8" Margin="4,8,0,8"/>

                  <!-- Group headers -->
                  <TextBlock Grid.Row="0" Grid.Column="2"
                             Margin="0,10,0,0" Padding="0,0,0,4"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).HdrVendre}"
                             FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource CourseraSuccessBrush}"
                             HorizontalAlignment="Center"/>
                  <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3"
                             Margin="0,10,0,0" Padding="0,0,0,4"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).HdrRetourner}"
                             FontWeight="SemiBold" FontSize="12"
                             Foreground="{DynamicResource CourseraWarningBrush}"
                             HorizontalAlignment="Center"/>

                  <!-- Column headers -->
                  <TextBlock Grid.Row="1" Grid.Column="0" Margin="12,0,8,0"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColTables}"
                             FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom"/>

                  <TextBlock Grid.Row="1" Grid.Column="2" Margin="8,0,0,0"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColGrand}"
                             FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                  <TextBlock Grid.Row="1" Grid.Column="4" Margin="8,0,0,0"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColMoyenne}"
                             FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                  <TextBlock Grid.Row="1" Grid.Column="6" Margin="8,0,12,0"
                             Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColPetit}"
                             FontSize="11" FontWeight="SemiBold"
                             Foreground="{DynamicResource CourseraDangerBrush}"
                             HorizontalAlignment="Center" VerticalAlignment="Bottom"/>

                  <!-- Data row -->
                  <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7"
                          Margin="0,6,0,0"
                          Padding="0,10,0,12"
                          BorderBrush="{DynamicResource CourseraBorderBrush}"
                          BorderThickness="0,1,0,0">
                    <Grid ColumnDefinitions="64,1,*,1,*,1,*">
                      <TextBlock Grid.Column="0" Margin="12,0,8,0"
                                 Text="{Binding TablesLabel}"
                                 FontSize="14" FontWeight="Bold"
                                 VerticalAlignment="Center"/>

                      <Border Grid.Column="1" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.6"/>

                      <!-- Grand -->
                      <Grid Grid.Column="2" Margin="8,0" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColPochette}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding PochetteGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColTotal}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding TotalGrandLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                      </Grid>

                      <Border Grid.Column="3" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>

                      <!-- Moyenne -->
                      <Grid Grid.Column="4" Margin="8,0" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColPochette}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding PochetteMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColTotal}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding TotalMoyenneLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                      </Grid>

                      <Border Grid.Column="5" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>

                      <!-- Petit -->
                      <Grid Grid.Column="6" Margin="8,0,12,0" ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColPochette}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding PochettePetitLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                          <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).ColTotal}"
                                     FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                          <TextBlock Text="{Binding TotalPetitLabel}" FontWeight="Bold"
                                     Foreground="{DynamicResource CourseraDangerBrush}"
                                     HorizontalAlignment="Center"/>
                        </StackPanel>
                      </Grid>
                    </Grid>
                  </Border>
                </Grid>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </ScrollViewer>
  </Grid>
</UserControl>
