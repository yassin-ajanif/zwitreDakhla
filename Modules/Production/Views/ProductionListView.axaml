<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Production.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Production.Views.ProductionListView"
             x:Name="ProductionListRoot"
             x:DataType="vm:ProductionListViewModel">
  <Grid RowDefinitions="Auto,*">
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="{Binding BtnNew}" Command="{Binding NewCommandeCommand}"/>
      <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
    </StackPanel>

    <ListBox Grid.Row="1" Margin="0,12,0,0"
             ItemsSource="{Binding Commandes}"
             SelectedItem="{Binding Selected}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0"
             beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditSelectedCommand}">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:CommandeProductionListItem">
            <Border Background="{DynamicResource CourseraSurfaceBrush}"
                    BorderBrush="{DynamicResource CourseraBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,14">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).MenuDelete}"
                            Command="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).DeleteCommandeCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>

              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Border Width="3" Height="22" CornerRadius="2"
                            Background="{DynamicResource CourseraPrimaryBrush}"/>
                    <TextBlock Text="{Binding Numero}" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Text="•" Opacity="0.45"/>
                    <TextBlock Text="{Binding FournisseurNom}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="•" Opacity="0.45"/>
                    <TextBlock Text="{Binding DateLabel}" FontSize="13" Opacity="0.75"/>
                  </StackPanel>
                </Grid>
                <TextBlock Text="{Binding SummaryLine2}" FontSize="13" Opacity="0.85"/>
                <TextBlock Text="{Binding SummaryLine3}" FontSize="13" FontWeight="SemiBold"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
