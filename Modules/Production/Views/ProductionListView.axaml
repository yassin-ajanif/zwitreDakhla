<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Production.ViewModels"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             xmlns:shared="using:GestionCommerciale.Shared.Views"
             x:Class="GestionCommerciale.Modules.Production.Views.ProductionListView"
             x:Name="ProductionListRoot"
             x:DataType="vm:ProductionListViewModel">
  <UserControl.Styles>
    <Style Selector="ComboBox.prod-list-filter">
      <Setter Property="MinWidth" Value="0"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>
  </UserControl.Styles>
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Spacing="8">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <Button Content="{Binding BtnNew}" Command="{Binding NewCommandeCommand}"/>
          <Button Content="{Binding BtnFilterDate}" Command="{Binding FilterDateCommand}"/>
        </StackPanel>
        <Button Grid.Column="2" Content="{Binding BtnResetFilters}" Command="{Binding ResetFiltersCommand}"
                HorizontalAlignment="Right"/>
      </Grid>
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ComboBox Classes="prod-list-filter"
                  PlaceholderText="{Binding WmFilterSupplier}"
                  ItemsSource="{Binding FilterFournisseurs}"
                  SelectedItem="{Binding SelectedFilterFournisseur, Mode=TwoWay}"/>
        <ComboBox Classes="prod-list-filter"
                  PlaceholderText="{Binding WmFilterCategorie}"
                  ItemsSource="{Binding FilterCategories}"
                  SelectedItem="{Binding SelectedFilterCategorie, Mode=TwoWay}"/>
        <ComboBox Classes="prod-list-filter"
                  PlaceholderText="{Binding WmFilterType}"
                  ItemsSource="{Binding FilterTypes}"
                  SelectedItem="{Binding SelectedFilterType, Mode=TwoWay}"/>
        <ComboBox Classes="prod-list-filter"
                  PlaceholderText="{Binding WmFilterExpiration}"
                  SelectedIndex="{Binding ExpirationFilterIndex}">
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblExpirationFilterAll}"/>
          </ComboBoxItem>
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblExpirationFilterEnCours}"/>
          </ComboBoxItem>
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblExpirationFilterTerminee}"/>
          </ComboBoxItem>
        </ComboBox>
        <ComboBox Classes="prod-list-filter"
                  PlaceholderText="{Binding WmSort}"
                  SelectedIndex="{Binding SortFilterIndex}">
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblSortDefault}"/>
          </ComboBoxItem>
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblSortBestMortality}"/>
          </ComboBoxItem>
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblSortBestAgrandissement}"/>
          </ComboBoxItem>
          <ComboBoxItem>
            <TextBlock Text="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).LblSortBestCommande}"/>
          </ComboBoxItem>
        </ComboBox>
      </StackPanel>
    </StackPanel>

    <ListBox Grid.Row="1" Margin="0,12,0,0"
             ItemsSource="{Binding Commandes}"
             SelectedItem="{Binding Selected}"
             Background="Transparent"
             BorderThickness="0"
             Padding="0"
             beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditSelectedCommand}">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
          </Style>
          <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
          <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
          </Style>
        </ListBox.Styles>
        <ListBox.ItemTemplate>
          <DataTemplate DataType="vm:CommandeProductionListItem">
            <Border Classes="report-shadow-bottom"
                    Background="{DynamicResource CourseraSurfaceBrush}"
                    BorderBrush="{DynamicResource CourseraBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    ClipToBounds="True">
              <Border.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).MenuDelete}"
                            Command="{Binding #ProductionListRoot.((vm:ProductionListViewModel)DataContext).DeleteCommandeCommand}"
                            CommandParameter="{Binding}"/>
                </ContextMenu>
              </Border.ContextMenu>

              <Grid RowDefinitions="Auto,Auto,Auto">
                <Border Grid.Row="0" Padding="16,14,16,12"
                        CornerRadius="11,11,0,0"
                        Background="{DynamicResource CourseraSurfaceMutedBrush}">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                      <Panel Width="4" Height="28">
                        <Border CornerRadius="2"
                                Background="{DynamicResource CourseraWarningBrush}"
                                IsVisible="{Binding !EstTerminee}"/>
                        <Border CornerRadius="2"
                                Background="{DynamicResource CourseraSuccessBrush}"
                                IsVisible="{Binding EstTerminee}"/>
                      </Panel>
                      <StackPanel Spacing="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding Numero}" FontSize="15" FontWeight="Bold"
                                     Foreground="{DynamicResource CourseraPrimaryBrush}"/>
                          <TextBlock Text="•" Opacity="0.35" VerticalAlignment="Center"/>
                          <TextBlock Text="{Binding FournisseurNom}" FontSize="14" FontWeight="SemiBold"
                                     VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DateLabel}" FontSize="12" Opacity="0.65"/>
                      </StackPanel>
                    </StackPanel>

                    <Panel Grid.Column="2" VerticalAlignment="Center">
                      <Border IsVisible="{Binding !EstTerminee}" Padding="10,5" CornerRadius="16"
                              Background="{DynamicResource CourseraWarningBrush}" BorderThickness="0">
                        <TextBlock Text="{Binding EtatLabel}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="White"/>
                      </Border>
                      <Border IsVisible="{Binding EstTerminee}" Padding="10,5" CornerRadius="16"
                              Background="{DynamicResource CourseraSuccessBrush}" BorderThickness="0">
                        <TextBlock Text="{Binding EtatLabel}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="White"/>
                      </Border>
                    </Panel>
                  </Grid>
                </Border>

                <WrapPanel Grid.Row="1" Margin="16,12,16,10" Orientation="Horizontal">
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          Background="#EAF2FF" BorderBrush="#BFDBFE" BorderThickness="1">
                    <TextBlock Text="{Binding CategorieCommandeNom}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource CourseraPrimaryBrush}"/>
                  </Border>
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          Background="#F5F3FF" BorderBrush="#DDD6FE" BorderThickness="1">
                    <TextBlock Text="{Binding TypeHuitreNom}" FontSize="12" FontWeight="SemiBold"
                               Foreground="#6D28D9"/>
                  </Border>
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="{Binding NaissainChipPrefix}" FontSize="12"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource CourseraSubtleTextBrush}"/>
                      <TextBlock Text="{Binding QuantiteNaissainLabel}" FontSize="12" FontWeight="Bold"
                                 VerticalAlignment="Center"
                                 Foreground="{DynamicResource CourseraSubtleTextBrush}"/>
                    </StackPanel>
                  </Border>
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          IsVisible="{Binding ShowMortalite}"
                          Background="{Binding MortaliteBadgeBackground}"
                          BorderBrush="{Binding MortaliteBadgeBorder}"
                          BorderThickness="1">
                    <TextBlock Text="{Binding MortaliteChipLabel}" FontSize="12" FontWeight="Bold"
                               Foreground="{Binding MortaliteBadgeForeground}"/>
                  </Border>
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          IsVisible="{Binding ShowAgrandissement}"
                          Background="{Binding AgrandissementBadgeBackground}"
                          BorderBrush="{Binding AgrandissementBadgeBorder}"
                          BorderThickness="1">
                    <TextBlock Text="{Binding AgrandissementChipLabel}" FontSize="12" FontWeight="Bold"
                               Foreground="{Binding AgrandissementBadgeForeground}"/>
                  </Border>
                  <Border Margin="0,0,8,8" Padding="10,5" CornerRadius="14"
                          IsVisible="{Binding ShowFacteur}"
                          Background="{Binding FacteurBadgeBackground}"
                          BorderBrush="{Binding FacteurBadgeBorder}"
                          BorderThickness="1">
                    <TextBlock Text="{Binding FacteurChipLabel}" FontSize="12" FontWeight="Bold"
                               Foreground="{Binding FacteurBadgeForeground}"/>
                  </Border>
                </WrapPanel>

                <Border Grid.Row="2" Padding="16,10"
                        CornerRadius="0,0,11,11"
                        Background="#F8FAFC"
                        BorderBrush="{DynamicResource CourseraBorderBrush}"
                        BorderThickness="0,1,0,0">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Text="{Binding OperationsChipLabel}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource CourseraSubtleTextBrush}"/>
                    <Panel Grid.Column="1" Margin="16,0,16,0" VerticalAlignment="Center">
                      <TextBlock Text="{Binding WaterOrDeadHuitresChipLabel}"
                                 FontSize="13" FontWeight="Bold"
                                 IsVisible="{Binding !EstTerminee}"
                                 Foreground="{DynamicResource CourseraPrimaryBrush}"/>
                      <TextBlock Text="{Binding WaterOrDeadHuitresChipLabel}"
                                 FontSize="13" FontWeight="Bold"
                                 IsVisible="{Binding EstTerminee}"
                                 Foreground="{DynamicResource CourseraStockAlertDetailBrush}"/>
                    </Panel>
                    <TextBlock Grid.Column="2" Text="{Binding ExpirationChipLabel}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               IsVisible="{Binding ShowExpirationChip}"
                               Foreground="{DynamicResource CourseraStockAlertDetailBrush}"/>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>

    <shared:ListPaginationBar Grid.Row="2" DataContext="{Binding Pagination}"/>
  </Grid>
</UserControl>
