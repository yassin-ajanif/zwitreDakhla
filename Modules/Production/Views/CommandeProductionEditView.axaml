<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Production.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Tiers.Models"
             xmlns:pm="using:GestionCommerciale.Modules.Production.Models"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Production.Views.CommandeProductionEditView"
             x:Name="CommandeEditRoot"
             x:DataType="vm:CommandeProductionEditViewModel">
  <Grid ColumnDefinitions="*,260" Margin="0,0,0,8">
    <ScrollViewer Grid.Column="0">
      <StackPanel Spacing="14" Margin="0,0,12,16">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Content="{Binding BtnBack}" Command="{Binding BackCommand}"/>
          <Button Content="{Binding BtnSave}" Command="{Binding SaveCommand}"/>
        </StackPanel>

        <Border Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding Numero}" FontWeight="Bold" FontSize="16"/>

            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,16,8" VerticalAlignment="Center">
                <TextBlock Text="{Binding LblFournisseur}" VerticalAlignment="Center" Opacity="0.7"/>
                <AutoCompleteBox MinWidth="220" MaxWidth="420"
                                 MinimumPrefixLength="1" MaxDropDownHeight="320"
                                 Watermark="{Binding WmFournisseurSearch}"
                                 ItemsSource="{Binding Fournisseurs}"
                                 ItemFilter="{Binding PartyAutocompleteFilter}"
                                 SelectedItem="{Binding SelectedFournisseur, Mode=TwoWay}"
                                 VerticalAlignment="Center">
                  <AutoCompleteBox.ValueMemberBinding>
                    <Binding Path="Nom"/>
                  </AutoCompleteBox.ValueMemberBinding>
                  <AutoCompleteBox.ItemTemplate>
                    <DataTemplate DataType="m:Tiers">
                      <TextBlock Text="{Binding Nom}"/>
                    </DataTemplate>
                  </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8" VerticalAlignment="Center">
                <TextBlock Text="{Binding LblDateCommande}" VerticalAlignment="Center" Opacity="0.7"/>
                <DatePicker SelectedDate="{Binding DateCommande}" VerticalAlignment="Center"/>
              </StackPanel>
            </WrapPanel>

            <Grid ColumnDefinitions="Auto,*,24,Auto,*" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding LblCategorieCommande}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,8"/>
              <ComboBox Grid.Row="0" Grid.Column="1" MinWidth="140" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                        ItemsSource="{Binding CategoriesCommande}"
                        SelectedItem="{Binding SelectedCategorieCommande, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="pm:CategorieCommande">
                    <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding LblQuantiteNaissain}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,8"/>
              <NumericUpDown Grid.Row="0" Grid.Column="4" Value="{Binding QuantiteNaissain}" Minimum="0" FormatString="N0" Margin="0,0,0,8"/>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding LblTypeHuitre}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,8"/>
              <ComboBox Grid.Row="1" Grid.Column="1" MinWidth="140" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                        ItemsSource="{Binding TypesNaissain}"
                        SelectedItem="{Binding SelectedTypeNaissain, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="pm:TypeNaissain">
                    <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LblTauxMortalite}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,8"/>
              <NumericUpDown Grid.Row="1" Grid.Column="4" Value="{Binding TauxMortalite}" Minimum="0" Maximum="100" FormatString="N1" Margin="0,0,0,8"/>

              <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding LblNote}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0"/>
              <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Text="{Binding Note}" Watermark="{Binding LblNote}"/>
            </Grid>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="{Binding SectionOperations}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="{Binding BtnAddOperation}" Command="{Binding AddOperationCommand}"
                  IsEnabled="{Binding CanAddOperation}"/>
        </Grid>

        <ListBox ItemsSource="{Binding Operations}"
                 SelectedItem="{Binding SelectedOperation}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0"
                 beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditSelectedOperationCommand}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0,0,0,14"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ProductionOperation">
              <Border Background="{DynamicResource CourseraSurfaceBrush}"
                      BorderBrush="{DynamicResource CourseraBorderBrush}"
                      BorderThickness="1"
                      CornerRadius="10"
                      ClipToBounds="True">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteOperation}"
                              Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeleteOperationCommand}"
                              CommandParameter="{Binding}"/>
                  </ContextMenu>
                </Border.ContextMenu>

                <Grid RowDefinitions="Auto,Auto">
                  <Border Grid.Row="0" Padding="14,10"
                          Background="{DynamicResource CourseraSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CourseraBorderBrush}"
                          BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DateShort}" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ModifiedAtLabel}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CourseraDangerBrush}"
                                   IsVisible="{Binding WasModified}" VerticalAlignment="Center"/>
                      </StackPanel>
                      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).LblTotalOperation}"
                                   Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalOperationLabel}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                  </Border>

                  <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="120,1,*,1,*,1,*">
                    <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Background="{DynamicResource ProdVendreBgBrush}" CornerRadius="8" Margin="0,8,4,8"/>
                    <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="3" Background="{DynamicResource ProdRetournerBgBrush}" CornerRadius="8" Margin="4,8,4,8"/>
                    <Border Grid.Row="0" Grid.Column="6" Grid.RowSpan="3" Background="{DynamicResource CourseraStockAlertBgBrush}" CornerRadius="8" Margin="4,8,0,8"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,10,0,0" Padding="0,0,0,4"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).HdrVendre}"
                               FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource CourseraSuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" Margin="0,10,0,0" Padding="0,0,0,4"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).HdrRetourner}"
                               FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource CourseraWarningBrush}" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="12,0,8,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTables}"
                               FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="8,0,0,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColGrand}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Margin="8,0,0,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColMoyenne}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Margin="8,0,12,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPetit}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource CourseraDangerBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"/>

                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7" Margin="0,6,0,0" Padding="0,10,0,12"
                            BorderBrush="{DynamicResource CourseraBorderBrush}" BorderThickness="0,1,0,0">
                      <Grid ColumnDefinitions="64,1,*,1,*,1,*">
                        <TextBlock Grid.Column="0" Margin="12,0,8,0" Text="{Binding TablesLabel}"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.6"/>
                        <Grid Grid.Column="2" Margin="8,0" ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochetteGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTotal}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalGrandLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                        <Border Grid.Column="3" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>
                        <Grid Grid.Column="4" Margin="8,0" ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochetteMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTotal}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalMoyenneLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                        <Border Grid.Column="5" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>
                        <Grid Grid.Column="6" Margin="8,0,12,0" ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochettePetitLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTotal}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalPetitLabel}" FontWeight="Bold"
                                       Foreground="{DynamicResource CourseraDangerBrush}" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <TextBlock Text="{Binding LblTotalCommande}" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding TotalCommandeLabel}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>

    <ScrollViewer Grid.Column="1">
      <StackPanel Spacing="16">
        <Border Padding="12"
                Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
          <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="{Binding LblCategoriesCommandePanel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
              <TextBox Watermark="{Binding WmNewCategorieCommande}" Text="{Binding NewCategorieCommandeNom, Mode=TwoWay}"/>
              <Button Content="{Binding BtnAddPanelCategorieCommande}" Command="{Binding AddPanelCategorieCommandeCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
            <Grid DockPanel.Dock="Top" RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="{Binding ColLookupNom}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ColLookupActif}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
              </Grid>
              <ListBox Grid.Row="1" ItemsSource="{Binding AllCategoriesCommande}"
                       SelectedItem="{Binding SelectedPanelCategorieCommande}"
                       MaxHeight="200"
                       beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditPanelCategorieCommandeCommand}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="pm:CategorieCommande">
                    <Border Padding="4,6" Background="Transparent">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteCategorieCommande}"
                                    Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeletePanelCategorieCommandeCommand}"
                                    CommandParameter="{Binding}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}" Opacity="0.85"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </DockPanel>
        </Border>

        <Border Padding="12"
                Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
          <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="{Binding LblTypesNaissainPanel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
              <TextBox Watermark="{Binding WmNewTypeNaissain}" Text="{Binding NewTypeNaissainNom, Mode=TwoWay}"/>
              <Button Content="{Binding BtnAddPanelTypeNaissain}" Command="{Binding AddPanelTypeNaissainCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
            <Grid DockPanel.Dock="Top" RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="{Binding ColLookupNom}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ColLookupActif}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
              </Grid>
              <ListBox Grid.Row="1" ItemsSource="{Binding AllTypesNaissain}"
                       SelectedItem="{Binding SelectedPanelTypeNaissain}"
                       MaxHeight="200"
                       beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditPanelTypeNaissainCommand}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="pm:TypeNaissain">
                    <Border Padding="4,6" Background="Transparent">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteTypeNaissain}"
                                    Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeletePanelTypeNaissainCommand}"
                                    CommandParameter="{Binding}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}" Opacity="0.85"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
