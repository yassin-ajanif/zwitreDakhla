<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GestionCommerciale.Modules.Production.ViewModels"
             xmlns:m="using:GestionCommerciale.Modules.Tiers.Models"
             xmlns:pm="using:GestionCommerciale.Modules.Production.Models"
             xmlns:conv="using:GestionCommerciale.Shared.Converters"
             xmlns:beh="using:GestionCommerciale.Shared.Behaviors"
             x:Class="GestionCommerciale.Modules.Production.Views.CommandeProductionEditView"
             x:Name="CommandeEditRoot"
             x:DataType="vm:CommandeProductionEditViewModel">
  <Grid ColumnDefinitions="*,260" Margin="0,0,0,8">
    <ScrollViewer Grid.Column="0">
      <StackPanel Spacing="14" Margin="0,0,12,16">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
          <Button Grid.Column="0" Content="{Binding BtnBack}" Command="{Binding BackCommand}" Margin="0,0,8,0"/>
          <Button Grid.Column="1" Content="{Binding BtnSave}" Command="{Binding SaveCommand}"/>
          <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="{Binding LblEtat}" VerticalAlignment="Center" Opacity="0.7"/>
            <ToggleSwitch IsChecked="{Binding EstTerminee, Mode=TwoWay}"
                          OnContent="{Binding LblTerminee}"
                          OffContent="{Binding LblEnCours}"/>
          </StackPanel>
        </Grid>

        <Border Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
          <StackPanel Spacing="12">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
              <Grid Grid.Column="0" RowDefinitions="Auto,*" VerticalAlignment="Stretch">
                <TextBlock Grid.Row="0" Text="{Binding Numero}" FontWeight="Bold" FontSize="16" VerticalAlignment="Top"/>
                <Button Grid.Row="1"
                        Command="{Binding OpenLinkedBonReceptionCommand}"
                        IsVisible="{Binding HasLinkedBonReceptionLabel}"
                        Padding="0"
                        MinHeight="0"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Left"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center"
                        Cursor="Hand">
                  <Border Padding="10,6"
                          Background="#DBEAFE"
                          BorderBrush="#93C5FD"
                          BorderThickness="1"
                          CornerRadius="4"
                          VerticalAlignment="Center">
                    <TextBlock Text="{Binding LinkedBonReceptionLabel}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#1E40AF"
                               TextAlignment="Center"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                  </Border>
                </Button>
              </Grid>
              <Border Grid.Column="2" Padding="14,10" CornerRadius="8"
                      Background="#FFF7ED"
                      BorderBrush="{DynamicResource CourseraWarningBrush}"
                      BorderThickness="1"
                      HorizontalAlignment="Right">
                <StackPanel Spacing="8">
                  <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding LblQuantiteNaissain}" FontWeight="SemiBold"
                               Foreground="{DynamicResource CourseraWarningBrush}" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding QuantiteNaissain}" Minimum="1" FormatString="N0" MinWidth="140"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding LblPrixAchatNaissain}" FontWeight="SemiBold"
                               Foreground="{DynamicResource CourseraWarningBrush}" VerticalAlignment="Center"/>
                    <NumericUpDown Value="{Binding PrixAchatNaissainHt}" ShowButtonSpinner="False"
                                   FormatString="0.##" Minimum="0.01" Increment="0.01" MinWidth="140"/>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
              <TextBlock Grid.Column="0" Text="{Binding LblFournisseur}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0"/>
              <AutoCompleteBox Grid.Column="1"
                               MinWidth="180"
                               MinimumPrefixLength="1" MaxDropDownHeight="320"
                               Watermark="{Binding WmFournisseurSearch}"
                               ItemsSource="{Binding Fournisseurs}"
                               ItemFilter="{Binding PartyAutocompleteFilter}"
                               SelectedItem="{Binding SelectedFournisseur, Mode=TwoWay}"
                               VerticalAlignment="Center">
                <AutoCompleteBox.ValueMemberBinding>
                  <Binding Path="Nom"/>
                </AutoCompleteBox.ValueMemberBinding>
                <AutoCompleteBox.ItemTemplate>
                  <DataTemplate DataType="m:Tiers">
                    <TextBlock Text="{Binding Nom}"/>
                  </DataTemplate>
                </AutoCompleteBox.ItemTemplate>
              </AutoCompleteBox>
              <Border Grid.Column="2" Margin="12,0,0,0"
                      Padding="14,10" CornerRadius="8"
                      Background="#FFF7ED"
                      BorderBrush="{DynamicResource CourseraWarningBrush}"
                      BorderThickness="1"
                      IsVisible="{Binding ShowTauxMortalite}"
                      VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                  <TextBlock Text="{Binding LblTauxMortalite}" FontWeight="SemiBold"
                             Foreground="{DynamicResource CourseraWarningBrush}" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding TauxMortaliteLabel}" FontSize="18" FontWeight="Bold"
                             Foreground="{DynamicResource CourseraWarningBrush}" VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </Grid>

            <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
              <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="{Binding LblDateCommande}" Opacity="0.7" FontSize="12"/>
                <DatePicker SelectedDate="{Binding DateCommande}"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                <TextBlock Text="{Binding LblDateExpiration}" Opacity="0.7" FontSize="12" HorizontalAlignment="Right"/>
                <DatePicker SelectedDate="{Binding DateExpiration}" HorizontalAlignment="Right"/>
              </StackPanel>
            </Grid>

            <Grid ColumnDefinitions="Auto,*,24,Auto,*" Margin="0,0,0,8">
              <TextBlock Grid.Column="0" Text="{Binding LblCategorieCommande}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0"/>
              <ComboBox Grid.Column="1" MinWidth="140" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding CategoriesCommande}"
                        SelectedItem="{Binding SelectedCategorieCommande, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="pm:CategorieCommande">
                    <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Column="3" Text="{Binding LblTypeHuitre}" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0"/>
              <ComboBox Grid.Column="4" MinWidth="140" HorizontalAlignment="Stretch"
                        ItemsSource="{Binding TypesHuitre}"
                        SelectedItem="{Binding SelectedTypeHuitre, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="pm:TypeHuitre">
                    <TextBlock Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>

            <StackPanel Spacing="4">
              <TextBlock Text="{Binding LblNote}" Opacity="0.7" FontSize="12"/>
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Text="{Binding Note}" Watermark="{Binding LblNote}"/>
                <Border Grid.Column="1" Margin="12,0,0,0"
                        Padding="14,10" CornerRadius="8"
                        VerticalAlignment="Center"
                        IsVisible="{Binding ShowRemainingHuitresChip}"
                        Background="#E0F2FE"
                        BorderBrush="#7DD3FC"
                        BorderThickness="1">
                  <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LblRemainingHuitresChipPrefix}" FontWeight="SemiBold"
                               Foreground="#0369A1" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RemainingHuitresAtWaterLabel}" FontSize="18" FontWeight="Bold"
                               Foreground="#0369A1" VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>
              </Grid>
            </StackPanel>
          </StackPanel>
        </Border>

        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="{Binding SectionOperations}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Content="{Binding BtnAddOperation}" Command="{Binding AddOperationCommand}"
                  IsEnabled="{Binding CanAddOperation}"/>
        </Grid>

        <ListBox x:Name="OperationsListBox"
                 ItemsSource="{Binding Operations}"
                 SelectedItem="{Binding SelectedOperation}"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="0"
                 beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditSelectedOperationCommand}">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="Padding" Value="0"/>
              <Setter Property="Margin" Value="0,0,0,14"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
            </Style>
            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
              <Setter Property="Background" Value="Transparent"/>
            </Style>
            <Style Selector="Border.operationCard">
              <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
              <Setter Property="BorderThickness" Value="1"/>
            </Style>
            <Style Selector="Border.operationCard.highlighted">
              <Setter Property="BorderBrush" Value="#EAB308"/>
              <Setter Property="BorderThickness" Value="3"/>
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:ProductionOperation">
              <Border Classes="operationCard"
                      Classes.highlighted="{Binding IsHighlighted}"
                      Background="{DynamicResource CourseraSurfaceBrush}"
                      CornerRadius="10"
                      ClipToBounds="True">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteOperation}"
                              Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeleteOperationCommand}"
                              CommandParameter="{Binding}"/>
                  </ContextMenu>
                </Border.ContextMenu>

                <Grid RowDefinitions="Auto,Auto">
                  <Border Grid.Row="0" Padding="14,10"
                          Background="{DynamicResource CourseraSurfaceMutedBrush}"
                          BorderBrush="{DynamicResource CourseraBorderBrush}"
                          BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                      <TextBlock Text="{Binding DateShort}" FontSize="15" FontWeight="SemiBold"/>
                      <TextBlock Text="{Binding ModifiedAtLabel}" FontSize="13" FontWeight="SemiBold"
                                 Foreground="{DynamicResource CourseraDangerBrush}"
                                 IsVisible="{Binding WasModified}" VerticalAlignment="Center"/>
                    </StackPanel>
                  </Border>

                  <Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="120,1,*,1,*,1,*">
                    <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3" Background="{DynamicResource ProdVendreBgBrush}" CornerRadius="8" Margin="0,8,4,8"/>
                    <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="3" Background="{DynamicResource ProdRetournerBgBrush}" CornerRadius="8" Margin="4,8,4,8"/>
                    <Border Grid.Row="0" Grid.Column="6" Grid.RowSpan="3" Background="{DynamicResource CourseraStockAlertBgBrush}" CornerRadius="8" Margin="4,8,0,8"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,10,0,0" Padding="0,0,0,4"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).HdrVendre}"
                               FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource CourseraSuccessBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="3" Margin="0,10,0,0" Padding="0,0,0,4"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).HdrRetourner}"
                               FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource CourseraWarningBrush}" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="12,0,8,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTables}"
                               FontSize="12" FontWeight="Bold" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Margin="8,0,0,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColGrand}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="4" Margin="8,0,0,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColMoyenne}"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.65" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                    <TextBlock Grid.Row="1" Grid.Column="6" Margin="8,0,12,0"
                               Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPetit}"
                               FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource CourseraDangerBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom"/>

                    <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="7" Margin="0,6,0,0" Padding="0,10,0,12"
                            BorderBrush="{DynamicResource CourseraBorderBrush}" BorderThickness="0,1,0,0">
                      <Grid ColumnDefinitions="120,1,*,1,*,1,*">
                        <TextBlock Grid.Column="0" Margin="12,0,8,0" Text="{Binding TablesLabel}"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.6"/>
                        <Grid Grid.Column="2" Margin="8,0" ColumnDefinitions="*,*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochetteGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTables}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TablesGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTotal}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalGrandLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                        <Border Grid.Column="3" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>
                        <Grid Grid.Column="4" Margin="8,0" ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochetteMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTables}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TablesMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                        <Border Grid.Column="5" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35"/>
                        <Grid Grid.Column="6" Margin="8,0,12,0" ColumnDefinitions="*,*">
                          <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColPochette}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding PochettePetitLabel}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CourseraDangerBrush}" HorizontalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).ColTables}"
                                       FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding TablesPetitLabel}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CourseraDangerBrush}" HorizontalAlignment="Center"/>
                          </StackPanel>
                        </Grid>
                      </Grid>
                    </Border>
                  </Grid>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border IsVisible="{Binding HasOperations}"
                Classes="report-shadow-soft"
                Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraPrimaryBrush}"
                BorderThickness="2"
                CornerRadius="10"
                Margin="0,4,0,0"
                Padding="0,0,0,14"
                ClipToBounds="True">
          <Grid RowDefinitions="Auto,Auto">
            <Border Grid.Row="0" Padding="14,12,14,12"
                    Background="{DynamicResource CourseraSurfaceMutedBrush}"
                    BorderThickness="0"
                    CornerRadius="8,8,0,0">
              <TextBlock Text="{Binding LblTotauxRow}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </Border>

            <Grid Grid.Row="1" Margin="10,10,10,0" ColumnDefinitions="120,1,*,1,*,1,*">
              <StackPanel Grid.Column="0" Margin="4,12,8,12" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="{Binding ColTables}" FontSize="10" Opacity="0.55"/>
                <TextBlock Text="{Binding TotalTablesLabel}" FontSize="14" FontWeight="Bold"/>
              </StackPanel>
              <Border Grid.Column="1" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.6" Margin="0,12,0,12"/>

              <Border Grid.Column="2" Margin="0,10,4,10" Padding="12,16"
                      Background="{DynamicResource ProdVendreBgBrush}"
                      BorderBrush="{DynamicResource CourseraSuccessBrush}"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid ColumnDefinitions="*,*,*">
                  <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColPochette}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPochetteGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColTables}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalTablesGrandLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColTotal}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalGrandHuitresLabel}" FontWeight="Bold" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Column="3" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35" Margin="0,12,0,12"/>

              <Border Grid.Column="4" Margin="4,10,4,10" Padding="12,16"
                      Background="{DynamicResource ProdRetournerBgBrush}"
                      BorderBrush="{DynamicResource CourseraWarningBrush}"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid ColumnDefinitions="*,*">
                  <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColPochette}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPochetteMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColTables}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalTablesMoyenneLabel}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Grid>
              </Border>

              <Border Grid.Column="5" Width="1" Background="{DynamicResource CourseraBorderBrush}" Opacity="0.35" Margin="0,12,0,12"/>

              <Border Grid.Column="6" Margin="4,10,0,10" Padding="12,16"
                      Background="{DynamicResource CourseraStockAlertBgBrush}"
                      BorderBrush="{DynamicResource CourseraDangerBrush}"
                      BorderThickness="1"
                      CornerRadius="8">
                <Grid ColumnDefinitions="*,*">
                  <StackPanel Grid.Column="0" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColPochette}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPochettePetitLabel}" FontWeight="SemiBold"
                               Foreground="{DynamicResource CourseraDangerBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ColTables}" FontSize="10" Opacity="0.55" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalTablesPetitLabel}" FontWeight="SemiBold"
                               Foreground="{DynamicResource CourseraDangerBrush}" HorizontalAlignment="Center"/>
                  </StackPanel>
                </Grid>
              </Border>
            </Grid>
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <ScrollViewer Grid.Column="1">
      <StackPanel Spacing="16">
        <Border Padding="12"
                Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
          <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="{Binding LblCategoriesCommandePanel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
              <TextBox Watermark="{Binding WmNewCategorieCommande}" Text="{Binding NewCategorieCommandeNom, Mode=TwoWay}"/>
              <Button Content="{Binding BtnAddPanelCategorieCommande}" Command="{Binding AddPanelCategorieCommandeCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
            <Grid DockPanel.Dock="Top" RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="{Binding ColLookupNom}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ColLookupActif}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
              </Grid>
              <ListBox Grid.Row="1" ItemsSource="{Binding AllCategoriesCommande}"
                       SelectedItem="{Binding SelectedPanelCategorieCommande}"
                       MaxHeight="200"
                       beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditPanelCategorieCommandeCommand}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="pm:CategorieCommande">
                    <Border Padding="4,6" Background="Transparent">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteCategorieCommande}"
                                    Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeletePanelCategorieCommandeCommand}"
                                    CommandParameter="{Binding}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}" Opacity="0.85"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </DockPanel>
        </Border>

        <Border Padding="12"
                Background="{DynamicResource CourseraSurfaceBrush}"
                BorderBrush="{DynamicResource CourseraBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
          <DockPanel LastChildFill="True">
            <TextBlock DockPanel.Dock="Top" Text="{Binding LblTypesHuitrePanel}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
              <TextBox Watermark="{Binding WmNewTypeHuitre}" Text="{Binding NewTypeHuitreNom, Mode=TwoWay}"/>
              <Button Content="{Binding BtnAddPanelTypeHuitre}" Command="{Binding AddPanelTypeHuitreCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
            <Grid DockPanel.Dock="Top" RowDefinitions="Auto,*">
              <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                <TextBlock Grid.Column="0" Text="{Binding ColLookupNom}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ColLookupActif}" FontWeight="SemiBold" Opacity="0.8" FontSize="11"/>
              </Grid>
              <ListBox Grid.Row="1" ItemsSource="{Binding AllTypesHuitre}"
                       SelectedItem="{Binding SelectedPanelTypeHuitre}"
                       MaxHeight="200"
                       beh:ListBoxOpenOnDoubleClick.OpenCommand="{Binding EditPanelTypeHuitreCommand}">
                <ListBox.ItemTemplate>
                  <DataTemplate DataType="pm:TypeHuitre">
                    <Border Padding="4,6" Background="Transparent">
                      <Border.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).MenuDeleteTypeHuitre}"
                                    Command="{Binding #CommandeEditRoot.((vm:CommandeProductionEditViewModel)DataContext).DeletePanelTypeHuitreCommand}"
                                    CommandParameter="{Binding}"/>
                        </ContextMenu>
                      </Border.ContextMenu>
                      <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding Nom}" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="1" Text="{Binding Actif, Converter={x:Static conv:BoolActifLabelConverter.Instance}}" Opacity="0.85"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </DockPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
