<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <Color x:Key="CourseraBgColor">#EEF4FF</Color>
    <Color x:Key="CourseraSurfaceColor">#FFFFFF</Color>
    <Color x:Key="CourseraSurfaceMutedColor">#EAF2FF</Color>
    <Color x:Key="CourseraBorderColor">#CFDCF7</Color>
    <Color x:Key="CourseraTextColor">#1F2937</Color>
    <Color x:Key="CourseraSubtleTextColor">#5E7296</Color>
    <Color x:Key="CourseraPrimaryColor">#2563EB</Color>
    <Color x:Key="CourseraPrimaryHoverColor">#1D4ED8</Color>
    <Color x:Key="CourseraSuccessColor">#16A34A</Color>
    <Color x:Key="CourseraDangerColor">#DC2626</Color>
    <Color x:Key="CourseraWarningColor">#D97706</Color>
    <Color x:Key="CourseraStockAlertBgColor">#FEF2F2</Color>
    <Color x:Key="CourseraStockAlertBorderColor">#FECACA</Color>
    <Color x:Key="CourseraStockAlertDetailColor">#991B1B</Color>

    <SolidColorBrush x:Key="CourseraBgBrush" Color="{StaticResource CourseraBgColor}"/>
    <SolidColorBrush x:Key="CourseraSurfaceBrush" Color="{StaticResource CourseraSurfaceColor}"/>
    <SolidColorBrush x:Key="CourseraSurfaceMutedBrush" Color="{StaticResource CourseraSurfaceMutedColor}"/>
    <SolidColorBrush x:Key="CourseraBorderBrush" Color="{StaticResource CourseraBorderColor}"/>
    <SolidColorBrush x:Key="CourseraTextBrush" Color="{StaticResource CourseraTextColor}"/>
    <SolidColorBrush x:Key="CourseraSubtleTextBrush" Color="{StaticResource CourseraSubtleTextColor}"/>
    <SolidColorBrush x:Key="CourseraPrimaryBrush" Color="{StaticResource CourseraPrimaryColor}"/>
    <SolidColorBrush x:Key="CourseraPrimaryHoverBrush" Color="{StaticResource CourseraPrimaryHoverColor}"/>
    <SolidColorBrush x:Key="CourseraSuccessBrush" Color="{StaticResource CourseraSuccessColor}"/>
    <SolidColorBrush x:Key="CourseraDangerBrush" Color="{StaticResource CourseraDangerColor}"/>
    <SolidColorBrush x:Key="CourseraWarningBrush" Color="{StaticResource CourseraWarningColor}"/>
    <SolidColorBrush x:Key="CourseraStockAlertBgBrush" Color="{StaticResource CourseraStockAlertBgColor}"/>
    <SolidColorBrush x:Key="CourseraStockAlertBorderBrush" Color="{StaticResource CourseraStockAlertBorderColor}"/>
    <SolidColorBrush x:Key="CourseraStockAlertDetailBrush" Color="{StaticResource CourseraStockAlertDetailColor}"/>
  </Styles.Resources>

  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource CourseraBgBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraTextBrush}"/>
  </Style>

  <Style Selector="UserControl">
    <Setter Property="Foreground" Value="{DynamicResource CourseraTextBrush}"/>
  </Style>

  <Style Selector="Border">
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource CourseraTextBrush}"/>
  </Style>

  <Style Selector="TextBlock.subtle">
    <Setter Property="Foreground" Value="{DynamicResource CourseraSubtleTextBrush}"/>
  </Style>

  <Style Selector="TextBox, ComboBox, NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10,7"/>
    <Setter Property="MinHeight" Value="36"/>
  </Style>

  <Style Selector="NumericUpDown">
    <Setter Property="ShowButtonSpinner" Value="False"/>
  </Style>

  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="12,8"/>
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraTextBrush}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource CourseraPrimaryBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraPrimaryBrush}"/>
    <Setter Property="Foreground" Value="White"/>
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraPrimaryHoverBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraPrimaryHoverBrush}"/>
  </Style>

  <Style Selector="Border.pos-cart-line">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="Margin" Value="0,0,0,6"/>
  </Style>

  <Style Selector="Border.pos-cart-line TextBlock.pos-cart-unit-price">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraSubtleTextBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <!-- Single-border inline controls (qty stepper, discount strip) -->
  <Style Selector="Border.pos-inline-group">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="MaxHeight" Value="36"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-inline-group > Border.pos-inline-sep">
    <Setter Property="Width" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="VerticalAlignment" Value="Stretch"/>
    <Setter Property="Margin" Value="0,6"/>
  </Style>

  <Style Selector="Border.pos-inline-group Button.pos-qty">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="0"/>
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="34"/>
    <Setter Property="MinWidth" Value="36"/>
    <Setter Property="MinHeight" Value="34"/>
    <Setter Property="FontSize" Value="18"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraPrimaryBrush}"/>
  </Style>

  <Style Selector="Border.pos-inline-group Button.pos-qty:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
  </Style>

  <Style Selector="Border.pos-inline-group NumericUpDown">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Height" Value="34"/>
    <Setter Property="MinHeight" Value="34"/>
    <Setter Property="MaxHeight" Value="34"/>
    <Setter Property="Padding" Value="6,0"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-inline-group NumericUpDown.pos-qty-value">
    <Setter Property="MinWidth" Value="56"/>
    <Setter Property="Width" Value="56"/>
    <Setter Property="TextAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-inline-group NumericUpDown.pos-discount-pct">
    <Setter Property="MinWidth" Value="40"/>
    <Setter Property="Width" Value="40"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <Style Selector="Border.pos-inline-group NumericUpDown.pos-discount-amount">
    <Setter Property="MinWidth" Value="68"/>
    <Setter Property="Width" Value="68"/>
    <Setter Property="FontSize" Value="13"/>
  </Style>

  <Style Selector="Border.pos-inline-group TextBlock.pos-inline-label">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraSubtleTextBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="0,0,8,0"/>
  </Style>

  <Style Selector="Border.pos-inline-group TextBlock.pos-inline-label-tight">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraSubtleTextBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="4,0"/>
  </Style>

  <Style Selector="Border.pos-inline-group TextBlock.pos-discount-minus">
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="8,0,0,0"/>
  </Style>

  <Style Selector="Border.pos-cart-line TextBlock.pos-cart-line-total">
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="MinWidth" Value="88"/>
    <Setter Property="TextAlignment" Value="Right"/>
  </Style>

  <Style Selector="Border.pos-cart-line Button.pos-cart-delete">
    <Setter Property="Background" Value="{DynamicResource CourseraStockAlertBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="36"/>
    <Setter Property="MinWidth" Value="36"/>
    <Setter Property="MinHeight" Value="36"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-cart-line Button.pos-cart-delete:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraDangerBrush}"/>
  </Style>

  <Style Selector="Border.pos-cart-line Button.pos-cart-delete:pointerover Path">
    <Setter Property="Fill" Value="White"/>
  </Style>

  <Style Selector="Button.pos-qty">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraPrimaryBrush}"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Button.pos-qty:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraPrimaryBrush}"/>
  </Style>

  <Style Selector="Button.pos-delete">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Width" Value="32"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="MinWidth" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Button.pos-delete:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraStockAlertBgBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraDangerBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraDangerBrush}"/>
  </Style>

  <Style Selector="AutoCompleteBox.pos-footer-input">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Height" Value="40"/>
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="MaxHeight" Value="40"/>
    <Setter Property="MinWidth" Value="200"/>
    <Setter Property="Padding" Value="10,8"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-payment-chip">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Height" Value="40"/>
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="MaxHeight" Value="40"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-payment-chip ComboBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="MaxHeight" Value="32"/>
    <Setter Property="MinWidth" Value="108"/>
    <Setter Property="Padding" Value="4,0"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-payment-chip NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Height" Value="32"/>
    <Setter Property="MinHeight" Value="32"/>
    <Setter Property="MaxHeight" Value="32"/>
    <Setter Property="MinWidth" Value="96"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Border.pos-payment-chip TextBlock.pos-payment-suffix">
    <Setter Property="Foreground" Value="{DynamicResource CourseraSubtleTextBrush}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="2,0,6,0"/>
  </Style>

  <Style Selector="Border.pos-payment-chip Button.pos-delete">
    <Setter Property="Width" Value="28"/>
    <Setter Property="Height" Value="28"/>
    <Setter Property="MinWidth" Value="28"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="4,0,0,0"/>
  </Style>

  <Style Selector="Button.pos-add-split">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraPrimaryBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Height" Value="40"/>
    <Setter Property="MinHeight" Value="40"/>
    <Setter Property="MaxHeight" Value="40"/>
    <Setter Property="Padding" Value="12,0"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{DynamicResource CourseraPrimaryBrush}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="VerticalAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
  </Style>

  <Style Selector="Button.pos-add-split:pointerover">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceMutedBrush}"/>
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="{DynamicResource CourseraSurfaceBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CourseraBorderBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="10"/>
  </Style>

  <!-- DatePicker: avoid huge default stretch (especially the month segment) -->
  <Style Selector="DatePicker">
    <Setter Property="HorizontalAlignment" Value="Left"/>
    <Setter Property="MaxWidth" Value="318"/>
  </Style>
  <Style Selector="DatePicker ComboBox">
    <Setter Property="MinWidth" Value="44"/>
    <Setter Property="MaxWidth" Value="100"/>
  </Style>

  <!-- Reporting / dashboard cards -->
  <Style Selector="Border.report-shadow">
    <Setter Property="BoxShadow" Value="0 2 14 0 #182563EB, 0 1 3 0 #12000000"/>
  </Style>
  <Style Selector="Border.report-shadow-soft">
    <Setter Property="BoxShadow" Value="0 1 8 0 #14000000"/>
  </Style>
</Styles>
